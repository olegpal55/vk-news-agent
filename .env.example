# ==========================================
# VK NEWS AGENT - Конфигурация
# Скопируй в .env и заполни своими данными
# ==========================================

# ---------- YOUTUBE ----------
# console.cloud.google.com -> YouTube Data API v3 -> Credentials
YOUTUBE_API_KEY=AIzaSy_YOUR_KEY_HERE
# ID каналов через запятую (youtube.com -> About -> Share)
YOUTUBE_CHANNEL_IDS=UCxxxxxx,UCyyyyyy

# ---------- TWITCH ----------
# dev.twitch.tv/console -> Register Your Application
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
# ID игр (например: Dota 2 = 29595, CS2 = 32399)
TWITCH_GAME_IDS=29595,32399

# ---------- TIKTOK ----------
# rapidapi.com -> поиск TikTok Scraper -> Subscribe
TIKTOK_RAPIDAPI_KEY=your_rapidapi_key
# Хэштеги для поиска (Gaming без #)
TIKTOK_HASHTAGS=gaming,esports,dota2

# ---------- OPENAI ----------
# platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here

# ---------- VK ----------
# vk.com/dev -> Стандалон приложение -> Implicit Flow
# URL: https://oauth.vk.com/authorize?client_id=APP_ID&display=page&scope=wall,photos,groups&response_type=token&v=5.199
VK_ACCESS_TOKEN=vk1.a.your_token_here
# ID группы (без минуса)
VK_GROUP_ID=123456789

# ---------- НАСТРОЙКИ АГЕНТА ----------
# Интервал постинга в минутах (10-60)
POSTING_INTERVAL_MIN=30
# Максимум постов за один запуск (1-5)
MAX_POSTS_PER_RUN=3
